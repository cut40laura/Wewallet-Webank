{
	# Keep HTTP usable for the raw IP and unverified domains. Browsers still
	# require HTTPS for mic/camera, but text features should not be broken while
	# ICP/HTTPS is pending.
	auto_https disable_redirects
}

(wewallet_proxy) {
	request_body {
		max_size 25MB
	}

	handle_path /rtc/* {
		reverse_proxy realtime:8870
	}

	handle {
		reverse_proxy app:8787
	}
}

# Public IP fallback: text chat, profile, wallet, and loan estimate.
http://115.159.127.218 {
	import wewallet_proxy
}

# Domain HTTP fallback while ICP / certificate issuance is pending.
http://{$WEWALLET_SITE_DOMAIN}, http://www.{$WEWALLET_SITE_DOMAIN} {
	import wewallet_proxy
}

# Domain HTTPS: required for mic/camera and realtime calls after the domain is
# eligible for a trusted Let's Encrypt certificate.
https://{$WEWALLET_SITE_DOMAIN}, https://www.{$WEWALLET_SITE_DOMAIN} {
	import wewallet_proxy
}
